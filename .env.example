# ============================================================
# 灵桥 Creative Hub — 环境变量配置
# ============================================================
# 复制此文件为 .env 并填写实际值
# cp .env.example .env
# ============================================================

# ============================================================
# Platform / Hub 端口配置
# ============================================================
PLATFORM_PORT=8100
HUB_FRONTEND_PORT=5180
NODE_ENV=development
DEBUG=false
LOG_LEVEL=INFO

# ============================================================
# 模块端口配置
# ============================================================

# 素材抓取模块
CONTENT_MARKETING_BACKEND_PORT=8001
CONTENT_MARKETING_FRONTEND_PORT=5174

# KV 生成模块
KV_GENERATOR_BACKEND_PORT=8002
KV_GENERATOR_FRONTEND_PORT=5175

# 表情包模块
EMOJI_GENERATOR_BACKEND_PORT=8003
EMOJI_GENERATOR_FRONTEND_PORT=5176

# ============================================================
# 共享 LLM 文本模型（素材抓取 + KV 生成共用）
# ============================================================

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# 通义千问
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# 豆包（火山引擎）
DOUBAO_API_KEY=
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=doubao-seed-2-0-mini-260215

# Gemini
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
GEMINI_MODEL=gemini-2.0-flash

# ============================================================
# 共享生图模型（素材抓取 + KV 生成共用）
# ============================================================

# 即梦 Seedream（火山引擎）
JIMENG_API_KEY=
JIMENG_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
JIMENG_MODEL=doubao-seedream-4-5-251128

# NanoBanana（Gemini Flash Image）
NANOBANANA_API_KEY=
NANOBANANA_BASE_URL=
NANOBANANA_MODEL=gemini-3.1-flash-image-preview

# ============================================================
# KV 生成模块专用 — Gemini 生图
# ============================================================
GEMINI_IMAGE_API_KEY=
GEMINI_IMAGE_BASE_URL=https://www.lemonapi.ai/v1
GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview

# ============================================================
# 表情包模块专用
# ============================================================

# 图像分析 API
ANALYZER_API_URL=
ANALYZER_API_KEY=
ANALYZER_MODEL=gemini-3-pro-preview

# 图像生成 模型A（Gemini 生图）
GENERATOR_A_API_URL=
GENERATOR_A_API_KEY=
GENERATOR_A_MODEL=gemini-3-pro-image-preview
GENERATOR_A_TIMEOUT=120
GENERATOR_A_LABEL=Gemini 生图

# 图像生成 模型B（即梦 Seedream）
GENERATOR_B_API_URL=https://ark.cn-beijing.volces.com/api/v3
GENERATOR_B_API_KEY=
GENERATOR_B_MODEL=doubao-seedream-5-0-260128
GENERATOR_B_TIMEOUT=120
GENERATOR_B_LABEL=即梦 Seedream

# 图像生成 模型C（Gemini Flash）
GENERATOR_C_API_URL=
GENERATOR_C_API_KEY=
GENERATOR_C_MODEL=gemini-3.1-flash-image-preview
GENERATOR_C_TIMEOUT=120
GENERATOR_C_LABEL=Gemini Flash 生图

DEFAULT_GENERATOR=a

# ============================================================
# 素材抓取模块专用 — 热搜数据源
# ============================================================
HOTLIST_API_URL=https://api.gumengya.com/Api

# ============================================================
# 存储配置
# ============================================================
DATA_ROOT=./data
DATA_RETENTION_DAYS=30

# ============================================================
# 并发与限流（各模块共用）
# ============================================================
MAX_CONCURRENT=3
RATE_LIMIT_PER_MINUTE=10
